[ ! -e /etc/config/wireless ] && exit 0

. /lib/functions.sh

board=$(board_name)

case "$board" in
gemtek,xr1710g-ubi|\
gemtek,w1700k-ubi)
	uci get wireless.radio0.country > /dev/null 2>&1 || uci set wireless.radio0.country='US'
	uci get wireless.radio1.country > /dev/null 2>&1 || uci set wireless.radio1.country='US'
	uci get wireless.radio2.country > /dev/null 2>&1 || uci set wireless.radio2.country='US'

	uci commit wireless
	;;
esac

exit 0
