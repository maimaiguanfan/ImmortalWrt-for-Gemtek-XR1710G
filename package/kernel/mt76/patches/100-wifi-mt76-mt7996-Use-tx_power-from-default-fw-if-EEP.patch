From aaf90b24fde77a38ee9f0a60d7097ded6a94ad1f Mon Sep 17 00:00:00 2001
From: Ivan Mironov <mironov.ivan@gmail.com>
Date: Mon, 17 Mar 2025 01:31:11 +0100
Subject: [PATCH] wifi: mt76: mt7996: Use tx_power from default fw if EEPROM
 contains 0s

Some Banana Pi BPI-R4-NIC-BE14 WiFi modules are sold with zeros instead
of usable tx_power values in EEPROM for 2.4 GHz and 5 GHz bands.

This patch replaces tx_power zeros with default values from firmware
files while keeping the rest of the EEPROM data intact (including valid
6 GHz tx_power table).

Also boost low tx_power values to the firmware default maximum for
devices with incomplete factory calibration data (e.g. Gemtek XR1710G).

Signed-off-by: Ivan Mironov <mironov.ivan@gmail.com>
Cc: stable@vger.kernel.org
Fixes: 98686cd21624 ("wifi: mt76: mt7996: add driver for MediaTek Wi-Fi 7 (802.11be) devices")
Closes: https://github.com/openwrt/openwrt/issues/17489
Link: https://github.com/openwrt/mt76/pull/954
---
 mt7996/eeprom.c | 64 +++++++++++++++++++++++++++++++++++++++++++++++--
 1 file changed, 62 insertions(+), 2 deletions(-)

--- a/mt7996/eeprom.c
+++ b/mt7996/eeprom.c
@@ -95,6 +95,60 @@ mt7996_eeprom_parse_stream(const u8 *eep
 	}
 }
 
+/* Minimum acceptable tx_power value in half-dBm units.
+ * Values below this are considered invalid/calibration-missing and
+ * will be replaced with firmware defaults.
+ * 0x14 = 20 half-dBm = 10 dBm (conservative lower bound)
+ */
+#define MT7996_MIN_TX_POWER	0x14
+
+static void
+mt7996_eeprom_fixup_tx_power(struct mt7996_dev *dev, const u8 *def)
+{
+	u8 *eeprom = dev->mt76.eeprom.data;
+	int i;
+	bool fixed = false;
+
+	/* 2.4 GHz band - single tx_power entry */
+	if (eeprom[MT_EE_TX0_POWER_2G] < MT7996_MIN_TX_POWER) {
+		eeprom[MT_EE_TX0_POWER_2G] = def[MT_EE_TX0_POWER_2G];
+		fixed = true;
+	}
+
+	/* 5 GHz band - 5 tx_power entries covering sub-bands */
+	for (i = MT_EE_TX0_POWER_5G; i < MT_EE_TX0_POWER_5G + 5; ++i) {
+		if (eeprom[i] < MT7996_MIN_TX_POWER) {
+			eeprom[i] = def[i];
+			fixed = true;
+		}
+	}
+
+	/* 6 GHz band - 8 tx_power entries covering sub-bands */
+	for (i = MT_EE_TX0_POWER_6G; i < MT_EE_TX0_POWER_6G + 8; ++i) {
+		if (eeprom[i] < MT7996_MIN_TX_POWER) {
+			eeprom[i] = def[i];
+			fixed = true;
+		}
+	}
+
+	if (fixed)
+		dev_warn(dev->mt76.dev,
+			 "eeprom tx_power too low or zero, using firmware defaults\n");
+}
+
+static u8 mt7996_eeprom_max_tx_power(const u8 *data, int start, int count)
+{
+	u8 max = 0;
+	int i;
+
+	for (i = start; i < start + count; i++)
+		if (data[i] > max)
+			max = data[i];
+
+	return max;
+}
+
 static bool mt7996_eeprom_variant_valid(struct mt7996_dev *dev, const u8 *def)
 {
 #define FEM_INT	0
@@ -136,6 +190,9 @@ mt7996_eeprom_check_or_use_default(struc
 	if (use_default)
 		dev_warn(dev->mt76.dev, "eeprom check failed, using default\n");
 
+	/* Always apply tx_power fixup, even for valid EEPROMs with
+	 * suspiciously low power values from incomplete factory data.
+	 */
 	mt7996_eeprom_fixup_tx_power(dev, fw->data);
 
 	if (!use_default && mt7996_eeprom_variant_valid(dev, fw->data))
 
